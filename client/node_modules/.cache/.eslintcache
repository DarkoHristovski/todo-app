lasses['todo-items-section']}>\n{props.loading && <Spinner/>}\n <ul className={classes['list-wrapper']}>\n{props.task.map(x=>  <TodoList  {...x}/>)}\n</ul>\n</section>\n);\n}\n\nexport default TodoItems","/Users/Darko 1 2/Documents/Projects/todo-app/client/src/components/TodoList.js",[],[],"/Users/Darko 1 2/Documents/Projects/todo-app/client/src/components/Button.js",[],[],"/Users/Darko 1 2/Documents/Projects/todo-app/client/src/components/Spinner.js",[],[],"/Users/Darko 1 2/Documents/Projects/todo-app/client/src/components/AddNewTask.js",["57"],[],"import classes from \"./AddNewTask.module.css\";\nimport { useState, useEffect } from \"react\";\n\n\n\nconst AddNewTask = (props) => {\n\n    const [inputTitle, setInputTitle] = useState('');\n    const [inputDescription, setInputDescription] = useState('');\n    \n    const titleChangeHandler = (event) =>{\n        setInputTitle(event.target.value)\n      }\n      \n      const descriptionChangeHandler = (event) =>{\n        setInputDescription(event.target.value)\n      }\n\n      const inputSubmitHandler = (event) => {\n      event.preventDefault();\n\n      if(inputTitle !== ''){\n        const inpuObjects={\n            name:inputTitle,\n            description: inputDescription,\n            id:Math.floor(Math.random() * 999)\n         }\n         props.addTaskHandler(inpuObjects)\n      }\n      \n      }\n\n\n  return (\n    <div className={classes[\"overlay\"]}>\n      <div className={classes[\"form-wrapper\"]}>\n        <p className={classes[\"title-form-wrapper\"]}>Add a Task</p>\n        <form className={classes.form} onSubmit={inputSubmitHandler}>\n          <label className={classes[\"form-label\"]} htmlFor=\"task-title\">\n            Title\n          </label>\n          <input\n            value={inputTitle}\n            onChange={titleChangeHandler}\n            placeholder=\"e.g, study for the test\"\n            className={classes[\"task-title\"]}\n            type=\"text\"\n            id=\"task-title\"\n          />\n          <label className={classes[\"form-label\"]} htmlFor=\"task-description\">\n            Description (optional)\n          </label>\n          <textarea\n           value={inputDescription}\n            onChange={descriptionChangeHandler}\n            placeholder=\"e.g, study for the test\"\n            className={classes[\"task-description\"]}\n            name=\"\"\n            id=\"task-description\"\n            cols=\"30\"\n            rows=\"5\"\n          ></textarea>\n          <button className=\"btn\" type=\"submit\">\n            Add a Task\n          </button>\n        </form>\n      </div>\n    </div>\n  );\n};\n\nexport default AddNewTask;\n",{"ruleId":"58","severity":1,"message":"59","line":1,"column":8,"nodeType":"60","messageId":"61","endLine":1,"endColumn":12},{"ruleId":"58","severity":1,"message":"62","line":2,"column":8,"nodeType":"60","messageId":"61","endLine":2,"endColumn":17},{"ruleId":"58","severity":1,"message":"63","line":2,"column":20,"nodeType":"60","messageId":"61","endLine":2,"endColumn":29},"no-unused-vars","'logo' is defined but never used.","Identifier","unusedVar","'TodoInput' is defined but never used.","'useEffect' is defined but never used."]